<?xml version="1.0" encoding="utf-8"?>
<!--
  ═══════════════════════════════════════════════════════════════════════════
  Iron Vault — MSIX Package Manifest
  ═══════════════════════════════════════════════════════════════════════════

  BEFORE SUBMITTING TO MICROSOFT PARTNER CENTER, update these three values
  to match what Partner Center shows for your registered app:

    1. Identity/@Name       — Package name, e.g. "12345YourName.IronVault"
    2. Identity/@Publisher  — Publisher ID, e.g. "CN=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
    3. Properties/PublisherDisplayName — Your display name in the Store

  Identity/@Version is injected automatically by the CI workflow from the
  git tag (v1.2.3 → 1.2.3.0).

  The certificate used to sign the package MUST have a Subject that exactly
  matches Identity/@Publisher. The self-signed cert created in CI is for
  local testing only; for Store submission the Store re-signs the package.
  ═══════════════════════════════════════════════════════════════════════════
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <!-- ── Identity ─────────────────────────────────────────────────────────
       Name and Publisher MUST match your Partner Center registration.
       Version is replaced at build time by the CI workflow.           -->
  <Identity
    Name="IronVault"
    Publisher="CN=IronVaultDev"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Iron Vault</DisplayName>
    <PublisherDisplayName>NeverMorewd</PublisherDisplayName>
    <!-- StoreLogo: 50×50 px, generated by CI; replace with your artwork -->
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>Retro tank-battle game — 100 hand-crafted stages, CRT aesthetic, bilingual.</Description>
  </Properties>

  <!-- Requires Windows 10 version 1809 (October 2018 Update) or later -->
  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
    <Resource Language="zh-CN" />
  </Resources>

  <Applications>
    <Application
      Id="App"
      Executable="IronVault.Desktop.exe"
      EntryPoint="Windows.FullTrustApplication">

      <uap:VisualElements
        DisplayName="Iron Vault"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png"
        Description="Retro tank-battle game — 100 hand-crafted stages."
        BackgroundColor="#0a0800">

        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          Square310x310Logo="Assets\Square310x310Logo.png"
          ShortName="Iron Vault">
          <uap:ShowNameOnTiles>
            <uap:ShowOn Tile="square150x150Logo" />
            <uap:ShowOn Tile="wide310x150Logo"   />
          </uap:ShowNameOnTiles>
        </uap:DefaultTile>

        <uap:SplashScreen
          Image="Assets\SplashScreen.png"
          BackgroundColor="#0a0800" />

      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Full-trust is required for .NET NativeAOT desktop apps -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
