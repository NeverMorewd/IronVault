<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="IronVault.Views.LevelSelectView">

  <Grid Background="{DynamicResource PipboyBackgroundBrush}">
    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="620"
                Spacing="0">

      <!-- ── Header ── -->
      <Border Classes="pipboy-panel" Margin="0,0,0,10">
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock x:Name="SelectLabel"
                     Classes="h1"
                     FontSize="20"
                     HorizontalAlignment="Center" />
          <TextBlock Text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                     Classes="dim"
                     FontSize="7"
                     HorizontalAlignment="Center" />
          <TextBlock x:Name="HintText"
                     Classes="dim"
                     FontSize="10"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- ── Level grid — 10 × 10, each slot 60 px (56 btn + 2 margin each side) ── -->
      <Border Classes="pipboy-panel" Margin="0,0,0,10" Padding="10">
        <WrapPanel x:Name="LevelGrid" />
      </Border>

      <!-- ── Selected level info + Deploy button ── -->
      <Border Classes="pipboy-panel" Margin="0,0,0,10" Padding="14,10">
        <Grid ColumnDefinitions="*,Auto">

          <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
            <TextBlock x:Name="StageNameText"
                       FontSize="13"
                       FontWeight="Bold" />
            <TextBlock x:Name="ThemeNameText"
                       Classes="dim"
                       FontSize="10" />
          </StackPanel>

          <Button x:Name="DeployBtn"
                  Grid.Column="1"
                  Classes="accent"
                  Padding="22,10"
                  FontSize="13"
                  VerticalAlignment="Center" />

        </Grid>
      </Border>

      <!-- ── Back button ── -->
      <Button x:Name="BackBtn"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Padding="10,8">
        <TextBlock x:Name="BackText" Classes="dim" FontSize="11" />
      </Button>

    </StackPanel>
  </Grid>

</UserControl>
