<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:IronVault.Desktop.Views"
             x:Class="IronVault.Desktop.Views.MainView">

  <!--
    Browser shell: identical three-screen layout to MainWindow but as a UserControl.
    IsVisible toggles control which screen is active — no page navigation overhead.
  -->
  <Grid>
    <views:MenuView    x:Name="MenuView"    />
    <views:GameView    x:Name="GameView"    IsVisible="False" />
    <views:UpgradeView x:Name="UpgradeView" IsVisible="False" />
  </Grid>

</UserControl>
