<pipboy:PipboyWindow xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:IronVault.Desktop.Views"
                    xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia"
                    x:Class="IronVault.Desktop.MainWindow"
                    Title="IRON VAULT"
                    Width="960" Height="700"
                    MinWidth="760" MinHeight="600"
                    WindowStartupLocation="CenterScreen">

  <!-- All three screens live in the same cell; IsVisible controls which is active -->
  <Grid>
    <views:MenuView    x:Name="MenuView"    />
    <views:GameView    x:Name="GameView"    IsVisible="False" />
    <views:UpgradeView x:Name="UpgradeView" IsVisible="False" />
  </Grid>

</pipboy:PipboyWindow>
