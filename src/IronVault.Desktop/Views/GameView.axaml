<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:renderer="clr-namespace:IronVault.Renderer.Controls;assembly=IronVault.Renderer"
             xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia"
             x:Class="IronVault.Desktop.Views.GameView">

  <!-- Root: horizontal split — game on left, HUD panel on right -->
  <Grid ColumnDefinitions="Auto,*">

    <!-- ── Game Canvas Area (CrtDisplay applies scanlines + beam + vignette) ── -->
    <Border Grid.Column="0"
            BorderBrush="{DynamicResource PipboyBorderBrush}"
            BorderThickness="2"
            Margin="8">
      <pipboy:CrtDisplay EnableScanlines="True"
                         ScanlineSpacing="3"
                         ScanlineHeight="1"
                         ScanlineOpacity="0.18"
                         EnableScanlineAnimation="True"
                         ScanlineAnimSpeed="28"
                         EnableScanBeam="True"
                         ScanBeamHeight="55"
                         ScanBeamSpeed="75"
                         EnableScanBeamGradient="True"
                         EnableNoise="True"
                         NoiseDensity="0.006"
                         NoiseOpacity="0.045"
                         NoisePixelSize="1"
                         NoiseRefreshIntervalMs="60"
                         EnableVignette="True"
                         VignetteIntensity="0.28"
                         EnableFlicker="False">
        <renderer:GameCanvas x:Name="GameCanvas" />
      </pipboy:CrtDisplay>
    </Border>

    <!-- ── HUD Panel (Pipboy style) ── -->
    <ScrollViewer Grid.Column="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="8,8,12,8" Spacing="10">

        <!-- Title -->
        <TextBlock x:Name="TitleText"
                   Text="IRON VAULT"
                   Classes="h1"
                   HorizontalAlignment="Center" />

        <Separator />

        <!-- Status Panel -->
        <Border Classes="pipboy-panel">
          <StackPanel Spacing="6">
            <TextBlock x:Name="StatusLabel" Text="STATUS" Classes="h2" />

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" x:Name="ModeLabel"    Text="MODE"    Classes="dim" />
              <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ModeText"     Text="CLASSIC" FontSize="10" />

              <TextBlock Grid.Row="1" Grid.Column="0" x:Name="WaveLabel"    Text="WAVE"    Classes="dim" />
              <TextBlock Grid.Row="1" Grid.Column="1" x:Name="WaveText"     Text="01" />

              <TextBlock Grid.Row="2" Grid.Column="0" x:Name="ScoreLabel"   Text="SCORE"   Classes="dim" />
              <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ScoreText"    Text="00000" />

              <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LivesLabel"   Text="LIVES"   Classes="dim" />
              <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LivesText"    Text="III" />

              <TextBlock Grid.Row="4" Grid.Column="0" x:Name="EnemiesLabel" Text="ENEMIES" Classes="dim" />
              <TextBlock Grid.Row="4" Grid.Column="1" x:Name="EnemiesText"  Text="20" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Player HP -->
        <Border Classes="pipboy-panel">
          <StackPanel Spacing="4">
            <TextBlock x:Name="ArmorLabel" Text="ARMOR" Classes="h2" />
            <pipboy:SegmentedBar x:Name="HpBar"
                                 Maximum="3"
                                 Value="3"
                                 SegmentCount="3" />
          </StackPanel>
        </Border>

        <!-- Active power-up effects -->
        <Border x:Name="EffectsPanel" Classes="pipboy-panel" IsVisible="False">
          <StackPanel Spacing="4">
            <TextBlock x:Name="EffectsLabel" Text="EFFECTS" Classes="h2" />
            <TextBlock x:Name="StarEffectText"   Text="★ SHIELD"   Classes="dim" FontSize="11" IsVisible="False" />
            <TextBlock x:Name="ClockEffectText"  Text="⏸ FREEZE"   Classes="dim" FontSize="11" IsVisible="False" />
            <TextBlock x:Name="ShovelEffectText" Text="⬛ FORTRESS" Classes="dim" FontSize="11" IsVisible="False" />
            <TextBlock x:Name="BoostEffectText"  Text="▲ OVERLOAD" Classes="dim" FontSize="11" IsVisible="False" />
          </StackPanel>
        </Border>

        <!-- Controls reference -->
        <Border Classes="pipboy-panel">
          <StackPanel Spacing="3">
            <TextBlock x:Name="ControlsLabel" Text="CONTROLS" Classes="h2" />
            <TextBlock x:Name="CtrlMove"  Text="[W/A/S/D]  MOVE"  Classes="dim" FontSize="11" />
            <TextBlock x:Name="CtrlFire"  Text="[SPACE]    FIRE"   Classes="dim" FontSize="11" />
            <TextBlock x:Name="CtrlPause" Text="[P]        PAUSE"  Classes="dim" FontSize="11" />
            <TextBlock x:Name="CtrlStart" Text="[ENTER]    START"  Classes="dim" FontSize="11" />
          </StackPanel>
        </Border>

        <!-- Action buttons -->
        <Button x:Name="StartButton"
                Content="[DEPLOY]"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" />

        <Button x:Name="PauseButton"
                Content="[HOLD]"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                IsEnabled="False" />

        <Button x:Name="MenuButton"
                Content="[RETREAT]"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Classes="danger" />

      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
